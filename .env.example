# ═══════════════════════════════════════════════════════════════
# AIlarkteams 环境变量配置
# ═══════════════════════════════════════════════════════════════
#
# 使用方法：
#   1. 复制本文件：cp .env.example .env
#   2. 编辑 .env，把 xxx 替换为你的真实值
#   3. 带 # 号的行是注释/可选项，去掉 # 号即可启用
#
# 最低配置（只需 3 个变量就能跑起来）：
#   FEISHU_APP_ID + FEISHU_APP_SECRET + DEEPSEEK_API_KEY
#
# ═══════════════════════════════════════════════════════════════

# ─── 飞书应用凭证 ───────────────────────────────────────────
# 在飞书开放平台创建应用后获取：https://open.feishu.cn
# 五个机器人可以共用一套凭证，也可以各自独立应用。

# 主凭证（脑暴机器人使用，其他机器人未单独配置时也用这个）
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# 规划机器人（不配则复用上面的主凭证）
# PLANNER_FEISHU_APP_ID=cli_xxx
# PLANNER_FEISHU_APP_SECRET=xxx

# 助手机器人（不配则复用主凭证）
# ASSISTANT_FEISHU_APP_ID=cli_xxx
# ASSISTANT_FEISHU_APP_SECRET=xxx

# 创意 Prompt 机器人（不配则复用主凭证）
# CREATIVE_FEISHU_APP_ID=cli_xxx
# CREATIVE_FEISHU_APP_SECRET=xxx

# 舆情监控机器人（不配则复用主凭证）
SENTIMENT_FEISHU_APP_ID=cli_xxx
SENTIMENT_FEISHU_APP_SECRET=xxx

# ─── 飞书 Webhook ──────────────────────────────────────────
# 用于把脑暴/规划的讨论过程实时推送到飞书群。
# 获取方式：在飞书群 → 设置 → 群机器人 → 添加「自定义机器人」→ 复制 Webhook 地址
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
# FEISHU_SECRET=                         # Webhook 签名密钥（可选，增加安全性）
# PLANNER_FEISHU_WEBHOOK=                # 规划专用群（不配则复用 FEISHU_WEBHOOK）

# ─── 大模型 API Keys ──────────────────────────────────────
# 三家大模型分工：DeepSeek=主力, 豆包=创意, Kimi=长文本

# DeepSeek（必须 —— 所有机器人都用）
# 申请地址：https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com    # 默认值，通常不需要改
# DEEPSEEK_MODEL=deepseek-chat                  # 默认模型

# 豆包（脑暴机器人必须 —— 用于创意角色「核桃仁」）
# 申请地址：https://console.volcengine.com
DOUBAO_API_KEY=xxx
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=ep-xxx                              # 替换为你的端点 ID

# Kimi（脑暴机器人必须 —— 用于素材角色和最终交付）
# 申请地址：https://platform.moonshot.cn
KIMI_API_KEY=xxx
# KIMI_BASE_URL=https://api.moonshot.cn/v1       # 默认值
# KIMI_MODEL=moonshot-v1-128k                    # 默认模型

# ─── 日历相关（助手机器人使用） ─────────────────────────────
# 操作用户个人日历需要用户授权的 token。
# 如果不需要日历功能，可以跳过这部分。

# FEISHU_CALENDAR_ID=                    # 指定日历 ID（可选，不填则自动获取主日历）
# FEISHU_TOKEN_CALENDAR_CREATE=          # 用户 token：往日历加日程（需 OAuth 授权获取）
# FEISHU_TOKEN_CALENDAR_GET=             # 用户 token：查看日程

# Google 日历（可选 —— 助手可以同时聚合飞书和 Google 日历）
# GOOGLE_CALENDAR_ICAL_URL=              # iCal 订阅地址（推荐，最简单）
# GOOGLE_CALENDAR_CREDENTIALS_JSON=      # 或用服务账号 JSON 路径

# ─── 定时推送（助手机器人使用） ─────────────────────────────
# FEISHU_PUSH_OPEN_ID=                   # 每日简报接收人的 open_id
                                          # 不配则自动推送给最近和机器人聊过天的人

# ─── 舆情监控相关 ──────────────────────────────────────────

# JustOneAPI（社交平台数据采集 —— 舆情机器人必须）
JOA_TOKEN=your_justoneapi_token
# JOA_BASE_URL=http://your-joa-server:30015  # JOA 服务地址（找管理员获取）

# GitHub 云存储（可选 —— 采集结果上传到 GitHub 仓库，方便 Claude Code 等 AI 工具直接调用）
# GITHUB_TOKEN=ghp_xxx                   # Personal Access Token（需 repo 权限）
# GITHUB_REPO=user/sentiment-data        # 格式: owner/repo

# ─── 其他 ──────────────────────────────────────────────────
# PORT=8080                              # PaaS 健康检查端口（Docker 部署时用）
# MEMO_STORE_PATH=                       # 备忘存储路径（默认 data/memos.json）
# LLM_REQUEST_TIMEOUT=120                # LLM 单次请求超时秒数（默认 120）
